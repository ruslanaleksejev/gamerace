rText = `Rändur: ${mangija.nimi}`;     document.getElementById('ajastu-nimi').innerText = `Ajastu: ${ajastud[mangija.tase].nimi}`;     document.getElementById('skoor-tekst').innerText = `Skoor: ${Math.floor(mangija.skoor)}`; }  function manguTsükkel() {     if (!mangKaib) return;     const praegune = ajastud[mangija.tase];      mnt.fillStyle = praegune.taust;     mnt.fillRect(0, 0, lõuend.width, lõuend.height);      if (klahvid.ArrowUp && mangija.y > 50) mangija.kiirusY -= 0.8;     if (klahvid.ArrowDown && mangija.y < 380) mangija.kiirusY += 0.8;      mangija.kiirusY *= 0.9;     mangija.y += mangija.kiirusY;      mnt.font = \"50px Arial\";     mnt.textAlign = \"center\";     mnt.fillText(praegune.auto, 60, mangija.y);      if (kaader % Math.floor(60 / raskusAste) === 0) {         takistused.push({ x: 850, y: Math.random() * 300 + 50, sümbol: praegune.viga });     }      takistused.forEach((t, i) => {         t.x -= praegune.kiirus * raskusAste;         mnt.fillText(t.sümbol, t.x, t.y);          if (t.x < 100 && t.x > 30 && Math.abs(t.y - mangija.y) < 35) mangLabi();         if (t.x < -50) {             takistused.splice(i, 1);             mangija.skoor += 10 * raskusAste;             uuendaUI();         }     });      if (kaader > 0 && kaader % 1000 === 0) jargmineTase();      kaader++;     requestAnimationFrame(manguTsükkel); }  function mangLabi() {     mangKaib = false;     alert(`Mäng läbi! Skoor: ${Math.floor(mangija.skoor)}`);     location.reload(); }  async function jargmineTase() {     if (mangija.tase < 5) {         mangija.tase++;         // Salvestame automaatselt         fetch('/api/salvesta', {             method: 'POST',             headers: {'Content-Type': 'application/json'},             body: JSON.stringify({ nimi: mangija.nimi, tase: mangija.tase, skoor: mangija.skoor })         });         takistused = [];         alert(`Uus tase: ${ajastud[mangija.tase].nimi}`);         uuendaUI();     } }  window.addEventListener('keydown', e => { if(klahvid.ha